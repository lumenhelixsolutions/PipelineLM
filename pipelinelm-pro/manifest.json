{
  "manifest_version": 3,
  "name": "PipelineLM Pro",
  "version": "1.0.0",
  "description": "Manage and view your entire NotebookLM media production across all notebooks",
  "default_locale": "en",
  "minimum_chrome_version": "114",
  "permissions": ["storage", "downloads", "activeTab", "sidePanel", "alarms", "contextMenus"],
  "host_permissions": ["*://notebooklm.google.com/*"],
  "background": { "service_worker": "background/sw.js", "type": "module" },
  "side_panel": { "default_path": "sidepanel/sidepanel.html" },
  "content_scripts": [{ "matches": ["*://notebooklm.google.com/*"], "js": ["content/content.js"], "run_at": "document_idle" }],
  "action": { "default_title": "PipelineLM Pro", "default_icon": { "16": "icons/icon16.png", "32": "icons/icon32.png" } },
  "icons": { "16": "icons/icon16.png", "32": "icons/icon32.png", "48": "icons/icon48.png", "128": "icons/icon128.png" },
  "web_accessible_resources": [{ "resources": ["shared/*"], "matches": ["*://notebooklm.google.com/*"] }]
}