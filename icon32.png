// ═══════════════════════════════════════════════════════════════
//  GENERATOR PROMPT TEMPLATES
// ═══════════════════════════════════════════════════════════════
export function buildGenerationPrompt(typeId, params, sources, customInstructions, language) {
  const type = STUDIO_TYPES.find(t => t.id === typeId);
  if(!type) return '';

  const langPrefix = language && language !== 'en' ? `Respond in ${LANGUAGES.find(l => l.code === language)?.name || language}. ` : '';

  const templates = {
    audio: `${langPrefix}Create an Audio Overview about the following sources. Format: ${params.format || 'podcast'}. Length: ${params.length || 'standard'}. Tone: ${params.style || 'conversational'}. Voice: ${params.voice || 'default'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`,

    video: `${langPrefix}Create a Video Overview script with visual direction. Format: ${params.format || 'explainer'}. Duration: ${params.length || 'medium'}. Visual style: ${params.style || 'clean'}. Music: ${params.music || 'subtle'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`,

    report: `${langPrefix}Write a comprehensive report. Type: ${params.format || 'analytical'}. Length: ${params.length || 'standard'}. Style: ${params.style || 'business'}. Sections: ${Array.isArray(params.sections) ? params.sections.join(', ') : params.sections || 'all'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`,

    quiz: `${langPrefix}Create a quiz with ${params.length || '10'} ${params.format || 'mixed'} questions. Difficulty: ${params.difficulty || 'medium'}. Focus: ${Array.isArray(params.style) ? params.style.join(', ') : params.style || 'key facts, concepts'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`,

    flashcard: `${langPrefix}Generate ${params.length || '20'} flashcards in ${params.format || 'term_definition'} format. Complexity: ${params.difficulty || 'mixed'}. Study mode: ${params.style || 'review'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`,

    slide_deck: `${langPrefix}Create a ${params.length || '10'}-slide ${params.format || 'presentation'} deck. Design: ${params.style || 'modern'}. Content density: ${params.density || 'standard'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`,

    mind_map: `${langPrefix}Generate a mind map with ${params.depth || '3'} levels. Layout: ${params.format || 'radial'}. Style: ${params.style || 'colorful'}. Connections: ${params.connect || 'all'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`,

    data_table: `${langPrefix}Extract structured data into a ${params.format || 'comparison'} table. ~${params.length || '25'} rows. Presentation: ${params.style || 'clean'}. Interactive: ${params.sortable || 'yes'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`,

    infographic: `${langPrefix}Create an ${params.format || 'statistical'} infographic. Detail: ${params.length || 'standard'}. Theme: ${params.style || 'modern'}. Charts: ${Array.isArray(params.charts) ? params.charts.join(', ') : params.charts || 'bar, pie, icons'}.\n\nSources:\n${sources.map((s,i) => `${i+1}. ${s.title}${s.snippet ? ': ' + s.snippet : ''}`).join('\n')}${customInstructions ? '\n\nAdditional instructions: ' + customInstructions : ''}`
  };

  return templates[typeId] || templates.report;
}
